# Weather uses Open-Meteo (no API key required)
# https://open-meteo.com/

# Support link (Payoneer / Ko-fi / etc.) — shown in Settings + board footer
NUXT_PUBLIC_SUPPORT_URL=https://link.payoneer.com/Token?t=YOUR_TOKEN&src=pl

# App feedback inbox
NUXT_PUBLIC_SUPPORT_EMAIL=chronoboard.app@gmail.com

# Admin dashboard password (Module 16)
NUXT_ADMIN_PASSWORD=

# Analytics service API secret for Plausible/Umami (Module 16)
NUXT_ANALYTICS_SECRET=
